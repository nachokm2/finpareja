# Base de datos PostgreSQL (Railway o local)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/finpareja

# Seguridad JWT — genera con: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=cambia_esto_por_un_valor_aleatorio_seguro_de_64_bytes
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Entorno
DEBUG=true
APP_ENV=development

# CORS — en producción lista los dominios exactos
ALLOWED_ORIGINS=["*"]
